# ---- Nexus AI server environment ----
# Copy this file to ".env" and fill in real values. This file is server-side
# only and must NEVER be committed or exposed to the browser.

# Port the Express API listens on
PORT=4000

# Comma-separated list of allowed front-end origins for CORS
CLIENT_ORIGINS=http://localhost:5173

# ---- Supabase (server-side) ----
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key — full DB access. Server-only. Never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Vault encryption ----
# 32-byte key (hex = 64 chars) used to AES-encrypt user API keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_ENCRYPTION_KEY=

# ---- Platform-level keys (optional fallbacks) ----
# Used for system tasks like the Step 10 intent router when a user has not
# supplied their own key. Per-user keys from the vault always take priority.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
HIGGSFIELD_API_KEY=
