# ---- Nexus AI server environment ----
# Copy this file to ".env" and fill in real values. This file is server-side
# only and must NEVER be committed or exposed to the browser.

# Port the Express API listens on
PORT=4000

# Comma-separated list of allowed front-end origins for CORS
CLIENT_ORIGINS=http://localhost:5173

# ---- Supabase (server-side) ----
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key — full DB access. Server-only. Never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Vault encryption ----
# 32-byte key (hex = 64 chars) used to AES-encrypt user API keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_ENCRYPTION_KEY=

# ---- Platform model keys (power the whole app, like Claude.ai) ----
# Set these so every signed-up user can chat with NO key setup. Per-user vault
# keys (optional) take priority when present.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
HIGGSFIELD_API_KEY=

# ---- Platform OAuth apps (so users connect their OWN accounts, like Claude) ----
# Register ONE OAuth app per service, add its redirect URI, and put the
# credentials here. Then every user gets one-click Connect (their own account).
# Native (YouTube) redirect URI:  <server>/api/native/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# MCP services redirect URI:      <server>/api/mcp/oauth/callback
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=
