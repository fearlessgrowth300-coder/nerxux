# ---- Nexus AI client environment ----
# Copy this file to ".env" and fill in real values.
# Only VITE_-prefixed vars are exposed to the browser. NEVER put provider
# API keys here — those live server-side in the encrypted vault.

# Public Supabase project URL (safe to expose)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Public Supabase anon key (safe to expose — protected by Row Level Security)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the Express backend. Leave blank in dev to use the Vite proxy (/api).
VITE_API_BASE_URL=
